{
  "expo": {
    "name": "Turnip Buds",
    "slug": "stalk-tracker",
    "description": "Watch your stalk stonks go up and down! Stalk your friend's prices for even more fun.",
    "platforms": [
      "ios",
      "android"
    ],
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.dmcnamara.turnipbuds",
      "buildNumber": "1.1.0",
      "supportsTablet": true,
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.dmcnamara.turnipbuds",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/transparent_icon_1024.png",
        "backgroundColor": "#66bb6a",
        "backgroundImage": "./assets/bg.png"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#66bb6a"
        }
      ],
      "expo-localization"
    ]
  }
}
