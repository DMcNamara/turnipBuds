{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "typeRoots": ["node_modules/@types"],
    "types": ["node", "jest"]
  },
  "compileOnSave": true,
  "include": ["src"],
  "exclude": ["src/**/*.spec.ts", "src/**/__tests__/**"]
}
